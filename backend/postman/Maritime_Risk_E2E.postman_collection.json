{
  "info": {
    "name": "Maritime Risk E2E (Live + Mock)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end backend demo: live poll, mock articles, enrichment traces, shipment risks, recommendations, feedback learning."
  },
  "item": [
    {
      "name": "1. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health ok', function () {",
              "  const j = pm.response.json();",
              "  pm.expect(j.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Preferences Baseline",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/preferences"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "pm.environment.set('w_cost_before', j.w_cost);",
              "pm.test('baseline weights loaded', function () {",
              "  pm.expect(j).to.have.property('w_cost');",
              "  pm.expect(j).to.have.property('w_speed');",
              "  pm.expect(j).to.have.property('w_risk');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Force Live Poll (target 5 news)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"weather\": true,\n  \"news\": true,\n  \"news_target_count\": 5,\n  \"gdelt_max_records\": 5,\n  \"include_followup\": false\n}"
        },
        "url": "{{base_url}}/api/admin/ingestion/poll"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('poll endpoint responded', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. Fetch Live NEWS (top 5)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/events?type=NEWS&limit=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const rows = pm.response.json() || [];",
              "const ids = rows.slice(0, 5).map(r => r.id);",
              "pm.environment.set('live_event_ids_csv', ids.join(','));",
              "pm.test('captured live event ids', function () {",
              "  pm.expect(ids.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Insert 5 Mock NEWS (default set)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pack_name\": \"asia_us_disruptions_v1\"\n}"
        },
        "url": "{{base_url}}/api/admin/events/mock-news/default-set"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "const ids = j.created_event_ids || [];",
              "pm.environment.set('mock_event_ids_csv', ids.join(','));",
              "pm.test('mock endpoint ok', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Bulk Enqueue Enrichment (live + mock)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const liveCsv = pm.environment.get('live_event_ids_csv') || '';",
              "const mockCsv = pm.environment.get('mock_event_ids_csv') || '';",
              "const parseCsv = (csv) => csv ? csv.split(',').map(s => parseInt(s, 10)).filter(n => !Number.isNaN(n)) : [];",
              "const combined = [...parseCsv(liveCsv), ...parseCsv(mockCsv)];",
              "pm.environment.set('combined_event_ids_json', JSON.stringify(combined));",
              "pm.environment.set('bulk_payload', JSON.stringify({ mode: 'enrich', event_ids: combined }));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "const ids = j.created_task_ids || [];",
              "pm.environment.set('task_ids_csv', ids.join(','));",
              "if (ids.length > 0) pm.environment.set('task_id_1', String(ids[0]));",
              "pm.test('bulk enqueue created tasks', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "  pm.expect(j.created_count).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{{bulk_payload}}"
        },
        "url": "{{base_url}}/api/research/tasks/bulk"
      }
    },
    {
      "name": "7. Research Progress Snapshot",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/research/progress"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "pm.test('progress shape', function () {",
              "  pm.expect(j).to.have.property('queued');",
              "  pm.expect(j).to.have.property('done');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "8. Task Trace (shows 3 agents outputs)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/research/tasks/{{task_id_1}}/trace"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const t = pm.response.json();",
              "const so = t.stage_outputs || {};",
              "pm.test('trace has three stage outputs', function () {",
              "  pm.expect(so.relevance_raw).to.not.eql(undefined);",
              "  pm.expect(so.impact_raw).to.not.eql(undefined);",
              "  pm.expect(so.action_raw).to.not.eql(undefined);",
              "});",
              "console.log('relevance_raw', so.relevance_raw);",
              "console.log('impact_raw', so.impact_raw);",
              "console.log('action_raw', so.action_raw);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "9. Findings",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/research/findings"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const rows = pm.response.json() || [];",
              "pm.test('findings returned', function () {",
              "  pm.expect(rows.length).to.be.greaterThan(0);",
              "});",
              "if (rows[0] && rows[0].event_id) pm.environment.set('event_id_1', String(rows[0].event_id));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10. Event Detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/events/{{event_id_1}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "pm.test('event enriched fields present', function () {",
              "  pm.expect(j).to.have.property('severity');",
              "  pm.expect(j).to.have.property('impacted_ports');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11. Shipments",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/shipments"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const rows = pm.response.json() || [];",
              "if (rows[0] && rows[0].id) pm.environment.set('shipment_id_1', String(rows[0].id));",
              "pm.test('shipments exist', function () {",
              "  pm.expect(rows.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "12. Shipment Risks",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/shipments/{{shipment_id_1}}/risks"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('shipment risks call succeeded', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "13. Generate Recommendations",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profile\": \"resilient\",\n  \"sku_ids\": [1,2],\n  \"horizon_days\": 30\n}"
        },
        "url": "{{base_url}}/api/recommendations/generate"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "const rec = (j.recommendations || [])[0];",
              "if (rec && rec.id) pm.environment.set('recommendation_id_1', String(rec.id));",
              "pm.test('recommendations generated', function () {",
              "  pm.expect((j.recommendations || []).length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "14. Feedback (too_expensive)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accepted\": false,\n  \"reason_code\": \"too_expensive\"\n}"
        },
        "url": "{{base_url}}/api/recommendations/{{recommendation_id_1}}/feedback"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('feedback accepted', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "15. Preferences After Feedback",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/preferences"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "pm.environment.set('w_cost_after', j.w_cost);",
              "pm.test('w_cost moved up after too_expensive feedback', function () {",
              "  const before = parseFloat(pm.environment.get('w_cost_before') || '0');",
              "  pm.expect(j.w_cost).to.be.greaterThan(before);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
